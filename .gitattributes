# Scripts that run inside a Linux container must keep LF endings whatever the
# checkout platform. A CRLF shebang fails as "bad interpreter: /usr/bin/env
# bash^M", which reads as a missing binary rather than a line-ending problem and
# costs an hour the first time.
docker/entrypoint.sh   text eol=lf
docker/supervisord.conf text eol=lf
*.sh                   text eol=lf
Dockerfile*            text eol=lf
