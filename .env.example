# Copy to .env.local and fill in. .env.local is gitignored.
#
# An AIOStreams manifest URL embeds an encrypted debrid config blob in its path,
# so it is a credential rather than a public addon URL. Mosaic does not read this
# file: addons are user-managed module settings (ADR 0021) set at runtime through
# the configureModule action. This is just where the value lives between runs.
MOSAIC_DEV_AIOSTREAMS_MANIFEST=""

MOSAIC_POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/mosaic?sslmode=disable"
MOSAIC_BOOTSTRAP_ADMIN_USERNAME="admin"
MOSAIC_BOOTSTRAP_ADMIN_PASSWORD="admin"
