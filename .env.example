# Copy to .env and fill in. .env is gitignored, and the dev stack
# (docker-compose.dev.yml) reads it automatically for variable substitution.
#
# An AIOStreams manifest URL embeds an encrypted debrid config blob in its path,
# so it is a credential rather than a public addon URL. Mosaic does not read this
# file: addons are user-managed module settings (ADR 0021) set at runtime through
# the configureModule action. This is just where the value lives between runs.
MOSAIC_DEV_AIOSTREAMS_MANIFEST=""

MOSAIC_POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/mosaic?sslmode=disable"
MOSAIC_BOOTSTRAP_ADMIN_USERNAME="admin"
MOSAIC_BOOTSTRAP_ADMIN_PASSWORD="admin"

# TMDB_RAC — a TMDB v4 "API Read Access Token", linked into the dev build with
# -ldflags -X so TMDB works out of the box (ADR 0072), exactly as the release
# binary is built. It comes from your .env or shell, never from a GitHub secret:
# secrets reach only CI runners, not a local build, so bring-your-own-token is
# the local-dev path. Leave empty to run without it — TMDB then needs a key set
# in Settings › TMDB, with Cinemeta as the zero-configuration floor meanwhile.
# Token: https://www.themoviedb.org/settings/api (the "API Read Access Token").
TMDB_RAC=""
